{
    "name": "wiratama/fylgja-wp-sync",
    "description": "Master/slave WordPress content sync via REST API.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6"
    },
    "autoload-dev": {
        "psr-4": {
            "Fylgja\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit"
    }
}
